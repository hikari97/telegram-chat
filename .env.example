TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_STRING_SESSION=

# Bisa pakai username publik seperti @sourcechannel.
# Untuk private channel, jalankan npm run dialogs lalu pakai id yang tampil.
# Banyak source bisa dipisah koma: @source1,@source2,-1001234567890
SOURCE_CHAT=@sourcechannel

# Channel tujuan. Akun Telegram Anda harus admin / punya izin post.
TARGET_CHAT=@targetchannel

# forward = meneruskan dengan attribution asli. Bisa ditolak jika source protected.
# copy = mengirim salinan konten ke channel tujuan.
RELAY_MODE=forward

# Opsional: regex untuk hanya meneruskan pesan tertentu.
# MATCH_REGEX=

# Opsional: ambil N pesan terakhir saat startup sebelum live listener aktif.
BACKFILL_LIMIT=0
